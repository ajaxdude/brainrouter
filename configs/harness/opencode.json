{
  "provider": {
    "brainrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Brainrouter",
      "options": { "baseURL": "http://127.0.0.1:9099/v1" },
      "models": { "auto": { "model": "auto", "name": "Brainrouter (auto)" } }
    }
  },
  "mcp": {
    "brainrouter": { "type": "local", "command": ["/path/to/brainrouter", "mcp", "--socket", "/run/user/$UID/brainrouter.sock"] }
  }
}
